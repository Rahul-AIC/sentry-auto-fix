# ── Sentry ──
SENTRY_WEBHOOK_SECRET=your_sentry_webhook_secret
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=your_sentry_project

# ── Bitbucket ──
BITBUCKET_USERNAME=your_bitbucket_username
BITBUCKET_APP_PASSWORD=your_bitbucket_app_password
BITBUCKET_WORKSPACE=your_bitbucket_workspace
BITBUCKET_REPO_SLUG=your_flutter_repo
BITBUCKET_BASE_BRANCH=main

# ── OpenAI ──
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4o

# ── Server ──
PORT=3000
NODE_ENV=production

# ── Safeguards ──
MAX_FILES_PER_FIX=3
MAX_DIFF_LINES=100
AUTO_MERGE_ENABLED=false
CONFIDENCE_THRESHOLD=0.8
NOTIFY_SLACK_WEBHOOK=https://hooks.slack.com/services/xxx/yyy/zzz
